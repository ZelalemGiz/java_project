<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="520.0" prefWidth="494.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controller.LoginController">
    
    <children>
        <!-- Main Card -->
        <VBox alignment="CENTER" maxHeight="624.0" maxWidth="593.0" minHeight="500.0" minWidth="400.0" prefHeight="425.0" prefWidth="450.0" spacing="20" style="-fx-background-color: #a79dbc; -fx-background-radius: 6%;" styleClass="card" StackPane.alignment="CENTER">
            
            <!-- Padding Region -->
            <Region prefHeight="10" />
         <Label styleClass="label-title" text="Welcome Back" textFill="#746f8a" />
            
            <!-- Subtitle -->
            <Label style="-fx-padding: 0 0 15 0;" styleClass="label-subtitle" text="Sign in to your account" />
            
            <!-- Username Field -->
            <VBox maxWidth="320" spacing="5">
                <Label style="-fx-text-fill: #475569; -fx-font-weight: bold; -fx-font-size: 13px;" text="Username" />
                <TextField fx:id="usernameField" prefHeight="42" promptText="Enter your username" styleClass="text-field" />
            </VBox>
            
            <!-- Password Field -->
            <VBox maxWidth="320" spacing="5">
                <Label style="-fx-text-fill: #475569; -fx-font-weight: bold; -fx-font-size: 13px;" text="Password" textFill="#a79dbc" />
                <PasswordField fx:id="passwordField" prefHeight="42" promptText="Enter your password" styleClass="password-field" />
            </VBox>
            
            <!-- Login Button -->
            <Button maxWidth="320" onAction="#handleLogin" prefHeight="45" style="-fx-margin-top: 10; -fx-font-size: 25px; -fx-font-weight: bold;" styleClass="button-primary" text="Login" />
            
            <!-- Forgot Password Link -->
            <Hyperlink onAction="#handleForgotPassword" style="-fx-text-fill: green ;-fx-font-weight: bold; -fx-font-size: 18px;" text="Forgot Password ?" />
            
            <!-- Bottom Padding -->
            <Region prefHeight="10" />
         <Button mnemonicParsing="false" onAction="#handleBack" prefHeight="36.0" prefWidth="120.0" text="← Back To Home" />
            
        </VBox>
    </children>
    
</StackPane>
