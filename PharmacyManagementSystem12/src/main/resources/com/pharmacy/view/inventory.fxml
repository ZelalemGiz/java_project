<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="622.0" prefWidth="740.0" spacing="20" style="-fx-padding: 30;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controller.InventoryController">
   <Button mnemonicParsing="false" onAction="#handleBack" prefHeight="39.0" prefWidth="121.0" text="← Back To Home" />
    <HBox alignment="CENTER_LEFT">
        <VBox prefHeight="53.0" prefWidth="336.0">
            <Label prefHeight="34.0" prefWidth="246.0" styleClass="label-title" text="Inventory Checks" />
            <Label styleClass="label-subtitle" text="Monitor low stock and status" />
        </VBox>
        <Region prefHeight="53.0" prefWidth="114.0" HBox.hgrow="ALWAYS" />
        <TextField fx:id="searchField" prefHeight="40.0" prefWidth="396.0" promptText="Search inventory..." style="-fx-margin-right: 10;" styleClass="text-field" />
    </HBox>
   <HBox spacing="20">
      <children>
         <VBox alignment="CENTER" prefHeight="100" styleClass="card" HBox.hgrow="ALWAYS">
            <children>
               <Label styleClass="label-subtitle" text="Total Stock" />
               <Label fx:id="labelTotalStock" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #10b981;" text="0" />
            </children>
         </VBox>
         <VBox alignment="CENTER" prefHeight="100" styleClass="card" HBox.hgrow="ALWAYS">
            <children>
               <Label styleClass="label-subtitle" text="Low Stock" />
               <Label fx:id="labelTotalLowStock" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: yellow;" text="0" />
            </children>
         </VBox>
         <VBox alignment="CENTER" prefHeight="100" styleClass="card">
            <children>
               <Label styleClass="label-subtitle" text="Expired Stock" />
               <Label fx:id="labelTotalExpiryStock" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #ef4444;" text="0" />
            </children>
         </VBox>
      </children>
   </HBox>
    <TableView fx:id="inventoryTable" prefHeight="310.0" prefWidth="605.0" styleClass="table-view" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <columns>
            <TableColumn text="Medicine ID" />
            <TableColumn text="Name" />
            <TableColumn text="Current Stock" />
            <TableColumn text="quantityStatus" />
         <TableColumn text="expiryStatus" />
         <TableColumn text="expiryWarninng" />
        </columns>
    </TableView>
</VBox>
