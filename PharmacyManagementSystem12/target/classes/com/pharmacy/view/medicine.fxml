<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="558.0" prefWidth="1086.0" styleClass="root" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controller.MedicineController">
   <children>
      <VBox spacing="20" style="-fx-padding: 30;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handleBack" prefHeight="43.0" prefWidth="126.0" text="← Back To Home" />
            <Label styleClass="label-title" text="Medicines Directory">
               <font>
                  <Font name="Times New Roman Bold" size="35.0" />
               </font>
            </Label>
            <HBox alignment="CENTER_LEFT" prefHeight="43.0" spacing="20">
               <children>
                  <Label styleClass="label-subtitle" text="Manage all your inventory items and stock" />
                  <Pane HBox.hgrow="ALWAYS" />
                  <TextField prefWidth="300.0" promptText="Search medicines..." styleClass="text-field" />
               </children>
            </HBox>
            <TableView fx:id="medicineTable" prefHeight="275.0" prefWidth="1026.0" styleClass="table-view" VBox.vgrow="ALWAYS">
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
               <columns>
                  <TableColumn text="ID" />
                  <TableColumn text="Name" />
                  <TableColumn text="Category" />
                  <TableColumn text="Cost (\$)" />
                  <TableColumn text="Price (\$)" />
                  <TableColumn text="Profit (\$)" />
                  <TableColumn text="Stock" />
                  <TableColumn text="Status" />
                  <TableColumn text="Date Added" />
                  <TableColumn text="Expiry" />
               </columns>
            </TableView>
            <HBox alignment="CENTER_RIGHT" spacing="15.0">
               <children>
                  <Button fx:id="btnAddUpdate" onAction="#handleAddUpdateMedicine" style="-fx-background-color: #10b981;" styleClass="button-primary" text="+ Add Medicine" />
                  <Button fx:id="btnDelete" onAction="#handleDeleteMedicine" style="-fx-background-color: #ef4444;" styleClass="button-primary" text="Delete" />
                  <Button fx:id="btnReport" onAction="#handleReportLowStock" style="-fx-background-color: #f59e0b;" styleClass="button-primary" text="Report Low Stock" />
                  <Button fx:id="btnRemoveExpired" onAction="#handleRemoveExpired" style="-fx-background-color: #ef4444;" styleClass="button-primary" text="Remove Expired" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
