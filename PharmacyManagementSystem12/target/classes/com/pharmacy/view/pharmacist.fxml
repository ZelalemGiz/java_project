<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20" style="-fx-padding: 30;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controller.PharmacistController">
   <Button mnemonicParsing="false" onAction="#handleBack" prefHeight="39.0" prefWidth="121.0" text="← Back To Home" />
    <HBox alignment="CENTER_LEFT">
        <VBox>
            <Label prefHeight="34.0" prefWidth="299.0" styleClass="label-title" text="Pharmacists &amp; Staff" />
            <Label styleClass="label-subtitle" text="Manage employees and system users" />
        </VBox>
        <Region prefHeight="53.0" prefWidth="76.0" HBox.hgrow="ALWAYS" />
        <TextField prefHeight="40.0" prefWidth="425.0" promptText="Search staff..." styleClass="text-field" />
    </HBox>
    
    <TableView fx:id="pharmacistTable" prefHeight="400.0" prefWidth="991.0" styleClass="table-view" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <columns>
            <TableColumn text="ID" />
            <TableColumn text="ID Number" />
            <TableColumn text="First Name" />
            <TableColumn text="Last Name" />
            <TableColumn text="Gender" />
            <TableColumn text="Phone" />
            <TableColumn text="Role" />
            <TableColumn text="Salary (\$)" />
            <TableColumn text="Date Employed" />
        </columns>
    </TableView>
   <HBox prefHeight="37.0" prefWidth="804.0">
      <children>
         <Pane prefHeight="48.0" prefWidth="39.0" />
           <Button onAction="#handleAddPharmacist" style="-fx-margin-left: 10; -fx-background-color: #10b981;" styleClass="button-primary" text="+ Add Pharmacist" />
         <Pane prefHeight="48.0" prefWidth="39.0" />
         <Button onAction="#handleUpdatePharmacist" prefHeight="38.0" prefWidth="153.0" style="-fx-margin-left: 10; -fx-background-color: #10b981;" styleClass="button-primary" text="Update" />
         <Pane prefHeight="48.0" prefWidth="39.0" />
           <Button onAction="#handleDeletePharmacist" prefHeight="41.0" prefWidth="135.0" style="-fx-margin-left: 10; -fx-background-color: #ef4444;" styleClass="button-primary" text="Delete" />
      </children>
   </HBox>
</VBox>
