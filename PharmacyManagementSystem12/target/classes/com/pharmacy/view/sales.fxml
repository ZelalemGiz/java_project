<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="533.0" prefWidth="1043.0" spacing="20" style="-fx-padding: 30;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controller.SalesController">
   <HBox prefHeight="33.0" prefWidth="1074.0">
      <children>
         <Button mnemonicParsing="false" onAction="#handleBack" prefHeight="43.0" prefWidth="163.0" text="← Back To Home" />
         <Region prefHeight="38.0" prefWidth="773.0" />
         <Button mnemonicParsing="false" onAction="#handleExportToCSV" prefHeight="38.0" prefWidth="118.0" style="-fx-background-color: #14ab28;" styleClass="button-primary" text="Export" />
         <Region prefHeight="53.0" prefWidth="46.0" />
      </children>
   </HBox>
    <HBox alignment="CENTER_LEFT">
        <VBox prefHeight="53.0" prefWidth="344.0">
            <Label styleClass="label-title" text="Sales &amp; Transactions" />
            <Label styleClass="label-subtitle" text="View all billing records" />
        </VBox>
        <Region prefHeight="53.0" prefWidth="46.0" HBox.hgrow="ALWAYS" />
        <TextField fx:id="searchField" prefHeight="40.0" prefWidth="700.0" promptText="Search sales..." style="-fx-margin-right: 10;" styleClass="text-field" />
      <Region prefHeight="53.0" prefWidth="0.0" />
    </HBox>
    <TableView fx:id="salesTable" prefHeight="266.0" prefWidth="1074.0" styleClass="table-view" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <columns>
            <TableColumn text="Sale ID" />
            <TableColumn text="Date" />
            <TableColumn text="Buyer Name" />
            <TableColumn text="Buyer Phone" />
            <TableColumn text="Medicine ID" />
            <TableColumn text="Qty" />
            <TableColumn text="Unit Price" />
            <TableColumn text="Discount" />
            <TableColumn text="Total Price" />
            <TableColumn text="Total Amount" />
            <TableColumn prefWidth="120" text="Branch" />
           <TableColumn prefWidth="120" text="Seller" />
        </columns>
    </TableView>
     <Button fx:id="btnDeleteSale" onAction="#handleDeleteSale" style="-fx-background-color: #ef4444;" styleClass="button-primary" text="Delete Sale" />
</VBox>
