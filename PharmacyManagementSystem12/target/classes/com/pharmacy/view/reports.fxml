<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="653.0" prefWidth="653.0" spacing="20" style="-fx-padding: 30;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controller.ReportsController">
   <Button mnemonicParsing="false" onAction="#handleBack" prefHeight="39.0" prefWidth="121.0" text="← Back To Home" />
    <HBox alignment="CENTER_LEFT">
        <VBox>
            <Label styleClass="label-title" text="Financial Reports" />
            <Label styleClass="label-subtitle" text="Analyze your sales and revenue" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#handleExportCSV" style="-fx-background-color: #3b82f6;" styleClass="button-primary" text="Export to CSV" />
    </HBox>
    
    <HBox spacing="20">
        <VBox alignment="CENTER" prefHeight="100" styleClass="card" HBox.hgrow="ALWAYS">
            <Label styleClass="label-subtitle" text="Total Revenue" />
            <Label fx:id="labelTotalRevenue" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #10b981;" text="\$0.00" />
        </VBox>
        <VBox alignment="CENTER" prefHeight="100" styleClass="card" HBox.hgrow="ALWAYS">
            <Label styleClass="label-subtitle" text="Total sales" />
            <Label fx:id="labelTotalSales" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: yellow;" text="\$0.00" />
        </VBox>
      <VBox alignment="CENTER" prefHeight="100" styleClass="card">
         <children>
            <Label styleClass="label-subtitle" text="Discounts Given" />
            <Label fx:id="labelDiscount" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #ef4444;" text="\$0.00" />
         </children>
      </VBox>
    </HBox>

    <TableView fx:id="reportsTable" prefHeight="311.0" prefWidth="593.0" styleClass="table-view" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <columns>
            <TableColumn text="Sale ID" />
            <TableColumn text="Total Amount (quantity)" />
            <TableColumn text="Pharmacist(seller) ID" />
         <TableColumn text="Total price (\$)" />
            <TableColumn text="Date" />
         <TableColumn />
        </columns>
    </TableView>
</VBox>
