<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="601.0" prefWidth="861.0" style="-fx-background-color: #a5c0d3;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controller.POSController">
    <left>
        <VBox prefHeight="653.0" prefWidth="553.0" spacing="15" style="-fx-padding: 20;">
         <HBox prefHeight="34.0" prefWidth="393.0">
            <children>
               <Button mnemonicParsing="false" onAction="#handleBack" prefHeight="36.0" prefWidth="120.0" text="← Back To Home" />
            </children>
         </HBox>
            <Label styleClass="label-title" text="Search Medicines" />
            <TextField fx:id="searchField" promptText="Search by name or category..." styleClass="text-field" />
            <TableView fx:id="medicineTable" styleClass="table-view" VBox.vgrow="ALWAYS">
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colMedName" text="Name" />
                    <TableColumn fx:id="colMedCategory" text="Category" />
                    <TableColumn fx:id="colMedPrice" text="Price ($)" />
                    <TableColumn fx:id="colMedStock" text="Amount" />
                </columns>
            </TableView>
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Label style="-fx-font-weight: bold;" text="Qty:" />
                <TextField fx:id="qtyField" prefWidth="60" styleClass="text-field" text="1" />
                <Button onAction="#handleAddToCart" style="-fx-background-color: #3b82f6;" styleClass="button-primary" text="Add to Cart &gt;&gt;" />
            </HBox>
        </VBox>
    </left>
    
    <center>
        <VBox prefHeight="653.0" prefWidth="355.0" spacing="15" style="-fx-padding: 20; -fx-background-color: #bfadad;">
            <Label styleClass="label-title" text="Current Cart" />
            <TableView fx:id="cartTable" prefWidth="365.0" styleClass="table-view" VBox.vgrow="ALWAYS">
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colCartName" text="Item" />
                    <TableColumn fx:id="colCartQty" text="Qty" />
                    <TableColumn fx:id="colCartPrice" text="Unit Price" />
                    <TableColumn fx:id="colCartTotal" text="Total" />
                </columns>
            </TableView>
            
            <HBox alignment="CENTER_RIGHT">
                <Button onAction="#handleRemoveFromCart" style="-fx-background-color: #ef4444;" styleClass="button-primary" text="Remove Selected Item" textFill="#bfadad" />
            </HBox>
         <AnchorPane prefHeight="116.0" prefWidth="311.0" style="-fx-border-radius: 10; -fx-border-color: gray; -fx-padding: 6;">
            <children>
               <Label layoutX="38.0" layoutY="17.0" prefHeight="38.0" prefWidth="67.0" styleClass="label-subtitle" />
               <TextField fx:id="buyer_name" layoutX="125.0" layoutY="16.0" prefHeight="40.0" prefWidth="222.0" promptText="Buyer Name:" />
               <Label layoutX="33.0" layoutY="63.0" prefHeight="38.0" prefWidth="75.0" styleClass="label-subtitle" />
               <TextField fx:id="buyer_phone" layoutX="128.0" layoutY="62.0" prefHeight="40.0" prefWidth="223.0" promptText="Buyer Phone:" />
            </children>
         </AnchorPane>
            
            <VBox spacing="10" styleClass="card">
                <HBox spacing="10" style="-fx-alignment: center; -fx-spacing: 10;">
                    <Label styleClass="label-subtitle" text="Subtotal:" />
                    <Label fx:id="subtotalLabel" style="-fx-font-weight: bold;" text="\$0.00" />
                </HBox>
                <HBox spacing="10" style="-fx-alignment: center; -fx-spacing: 10;">
                    <Label styleClass="label-subtitle" text="Discount (%):" />
                    <TextField fx:id="discountField" prefWidth="80" styleClass="text-field" text="0" />
                </HBox>
                <HBox spacing="10" style="-fx-alignment: center; -fx-spacing: 10;">
                    <Label styleClass="label-subtitle" text="Total Payable:" />
                    <Label fx:id="totalLabel" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #10b981;" text="\$0.00" />
                </HBox>
            </VBox>
            
            <HBox alignment="CENTER_RIGHT" spacing="15">
                <Button onAction="#handleCancelSale" style="-fx-background-color: #94a3b8;" styleClass="button-primary" text="Cancel Sale" />
                <Button onAction="#handleCompleteSale" style="-fx-background-color: #10b981; -fx-font-weight: bold;" styleClass="button-primary" text="Complete Transaction &amp; Print" />
            </HBox>
        </VBox>
    </center>
</BorderPane>
